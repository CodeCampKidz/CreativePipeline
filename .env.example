# Creative Automation Pipeline - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: OpenAI API key for DALL-E image generation
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Image generation configuration
IMAGE_MODEL=gpt-image-1.5
DALLE_QUALITY=standard
IMAGE_STYLE=vivid

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Max retries for API calls
MAX_RETRIES=3

# Storage backend ('local' or 's3')
STORAGE_BACKEND=local

# AWS S3 configuration (only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
S3_BUCKET=your-bucket-name-here
S3_PREFIX=campaigns/
S3_REGION=us-east-1

# Paths
DATA_DIR=data
OUTPUT_DIR=data/output
INPUT_ASSETS_DIR=data/input_assets
BRAND_CONFIG_PATH=data/brand/brand_config.yaml
FONTS_DIR=src/assets/fonts

# Web UI configuration
WEB_HOST=0.0.0.0
WEB_PORT=8080
CORS_ORIGINS=*
